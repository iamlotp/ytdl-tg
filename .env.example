# ── Telegram ────────────────────────────────────────────────────────────────
# Your bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow everyone (not recommended for production).
WHITELIST_IDS=123456789,987654321

# ── Google Drive ─────────────────────────────────────────────────────────────
# The ID of the Drive folder to upload into.
# Share this folder with the service account email as "Editor".
# Leave empty to upload to the service account's root (not recommended).
DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# ── Optional overrides ───────────────────────────────────────────────────────
# Path to the service account JSON inside the container (default: /config/service_account.json)
# SERVICE_ACCOUNT_PATH=/config/service_account.json

# Path to a Netscape-format cookies.txt for age-restricted content (default: /cookies/cookies.txt)
# COOKIES_PATH=/cookies/cookies.txt

# Local temp directory for downloads inside the container (default: /tmp/ytdl)
# DOWNLOAD_DIR=/tmp/ytdl
